import { Button, HorizontalBox, VerticalBox, Palette, CheckBox, LineEdit } from "std-widgets.slint";
import { DiffView, DiffLineData } from "widgets/diff-view.slint";
import { FolderView, FolderItemData } from "widgets/folder-view.slint";
import { TabBar, TabData } from "widgets/tab-bar.slint";
import { OpenDialog } from "dialogs/open-dialog.slint";

export { DiffLineData, FolderItemData, TabData }

component ConfirmDialog inherits Rectangle {
    in property <string> message: "";
    in property <bool> visible-flag: false;

    callback confirmed();
    callback cancelled();

    if visible-flag : Rectangle {
        // Overlay
        background: #00000080;

        TouchArea {
            clicked => { root.cancelled(); }
        }

        // Dialog box
        Rectangle {
            x: (parent.width - self.width) / 2;
            y: (parent.height - self.height) / 2;
            width: 400px;
            height: 160px;
            background: Palette.background;
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 8px;

            // Block clicks on dialog from propagating to overlay
            TouchArea {}

            VerticalLayout {
                padding: 20px;
                spacing: 16px;
                alignment: center;

                Text {
                    text: root.message;
                    font-size: 14px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                HorizontalLayout {
                    alignment: center;
                    spacing: 12px;

                    Button {
                        text: "Discard";
                        clicked => { root.confirmed(); }
                    }

                    Button {
                        text: "Cancel";
                        clicked => { root.cancelled(); }
                    }
                }
            }
        }
    }
}

export component MainWindow inherits Window {
    in-out property <string> window-title: "WinXMerge";
    title: window-title;
    width: 1200px;
    height: 800px;

    // File diff properties
    in-out property <[DiffLineData]> diff-lines;
    in-out property <int> diff-count: 0;
    in-out property <int> current-diff-index: -1;
    in-out property <string> left-path: "";
    in-out property <string> right-path: "";
    in-out property <string> status-text: "Select files or folders to compare";
    in-out property <bool> has-unsaved-changes: false;
    in-out property <bool> show-toolbar: true;

    // Folder comparison properties
    in-out property <[FolderItemData]> folder-items;
    in-out property <int> folder-selected-index: -1;
    // 0=file diff, 1=folder compare, 2=open dialog
    in-out property <int> view-mode: 2;

    // Diff options
    in-out property <bool> ignore-whitespace: false;
    in-out property <bool> ignore-case: false;

    // Search & Replace
    in-out property <bool> show-search: false;
    in-out property <string> search-query: "";
    in-out property <int> search-match-count: 0;

    // Undo/Redo
    in-out property <bool> can-undo: false;
    in-out property <bool> can-redo: false;

    // Unsaved changes dialog
    in-out property <bool> show-confirm-dialog: false;
    // 0=none, 1=open-left, 2=open-right, 3=open-folder-left, 4=open-folder-right, 5=new-compare
    in-out property <int> pending-action: 0;

    // Open dialog
    in-out property <string> open-left-path-input: "";
    in-out property <string> open-right-path-input: "";
    in-out property <bool> open-is-folder-mode: false;

    // Tabs
    in-out property <[TabData]> tab-list: [{title: "New", is-active: true, has-unsaved: false}];
    in-out property <int> active-tab-index: 0;

    callback open-left-file();
    callback open-right-file();
    callback open-folder-left();
    callback open-folder-right();
    callback next-diff();
    callback prev-diff();
    callback copy-to-right(int);
    callback copy-to-left(int);
    callback save-left();
    callback save-right();
    callback folder-item-double-clicked(int);
    callback back-to-folder-view();
    callback toggle-ignore-whitespace();
    callback toggle-ignore-case();
    callback search(string);
    callback search-next();
    callback search-prev();
    callback replace(/* search */ string, /* replacement */ string);
    callback replace-all(/* search */ string, /* replacement */ string);
    callback start-compare(/* left */ string, /* right */ string, /* is-folder */ bool);
    callback discard-and-proceed();
    callback new-tab();
    callback close-tab(int);
    callback switch-tab(int);
    callback undo();
    callback redo();

    // Helper: check unsaved before action
    function request-action(action: int) {
        if root.has-unsaved-changes {
            root.pending-action = action;
            root.show-confirm-dialog = true;
        } else {
            root.pending-action = action;
            root.discard-and-proceed();
        }
    }

    MenuBar {
        Menu {
            title: "File";
            MenuItem { title: "New Tab"; activated => { root.new-tab(); } }
            MenuItem { title: "New Compare..."; activated => { root.request-action(5); } }
            MenuSeparator {}
            MenuItem { title: "Open Left File..."; activated => { root.request-action(1); } }
            MenuItem { title: "Open Right File..."; activated => { root.request-action(2); } }
            MenuItem { title: "Open Left Folder..."; activated => { root.request-action(3); } }
            MenuItem { title: "Open Right Folder..."; activated => { root.request-action(4); } }
            MenuSeparator {}
            MenuItem { title: "Save Left"; enabled: root.has-unsaved-changes; activated => { root.save-left(); } }
            MenuItem { title: "Save Right"; enabled: root.has-unsaved-changes; activated => { root.save-right(); } }
        }
        Menu {
            title: "Edit";
            MenuItem { title: "Undo"; enabled: root.can-undo; activated => { root.undo(); } }
            MenuItem { title: "Redo"; enabled: root.can-redo; activated => { root.redo(); } }
            MenuSeparator {}
            MenuItem {
                title: "Find / Replace...";
                activated => { root.show-search = !root.show-search; }
            }
        }
        Menu {
            title: "View";
            MenuItem {
                title: root.show-toolbar ? "Hide Toolbar" : "Show Toolbar";
                activated => { root.show-toolbar = !root.show-toolbar; }
            }
            MenuItem {
                title: root.ignore-whitespace ? "✓ Ignore Whitespace" : "  Ignore Whitespace";
                activated => { root.toggle-ignore-whitespace(); }
            }
            MenuItem {
                title: root.ignore-case ? "✓ Ignore Case" : "  Ignore Case";
                activated => { root.toggle-ignore-case(); }
            }
        }
        Menu {
            title: "Merge";
            MenuItem { title: "Next Difference"; enabled: root.diff-count > 0; activated => { root.next-diff(); } }
            MenuItem { title: "Previous Difference"; enabled: root.diff-count > 0; activated => { root.prev-diff(); } }
            MenuSeparator {}
            MenuItem { title: "Copy Left to Right"; enabled: root.current-diff-index >= 0; activated => { root.copy-to-right(root.current-diff-index); } }
            MenuItem { title: "Copy Right to Left"; enabled: root.current-diff-index >= 0; activated => { root.copy-to-left(root.current-diff-index); } }
        }
    }

    VerticalLayout {
        // Tab bar
        TabBar {
            tabs: root.tab-list;
            active-index: root.active-tab-index;
            tab-clicked(idx) => { root.switch-tab(idx); }
            tab-close(idx) => { root.close-tab(idx); }
            new-tab => { root.new-tab(); }
        }

        // Toolbar
        if root.show-toolbar && root.view-mode != 2 : Rectangle {
            height: 40px;
            background: Palette.background.darker(0.03);
            border-color: Palette.border;
            border-width: 1px;

            HorizontalLayout {
                padding: 4px;
                spacing: 4px;
                alignment: start;

                Button {
                    text: "New...";
                    clicked => { root.request-action(5); }
                }

                Rectangle { width: 4px; }

                Button {
                    text: "Open Left...";
                    clicked => { root.request-action(1); }
                }

                Button {
                    text: "Open Right...";
                    clicked => { root.request-action(2); }
                }

                Rectangle { width: 8px; }

                if root.view-mode == 0 : Button {
                    text: "Save Left";
                    enabled: has-unsaved-changes;
                    clicked => { root.save-left(); }
                }

                if root.view-mode == 0 : Button {
                    text: "Save Right";
                    enabled: has-unsaved-changes;
                    clicked => { root.save-right(); }
                }

                if root.view-mode == 0 : Rectangle { width: 8px; }

                if root.view-mode == 0 : Button {
                    text: "◀ Prev";
                    enabled: diff-count > 0;
                    clicked => { root.prev-diff(); }
                }

                if root.view-mode == 0 : Button {
                    text: "Next ▶";
                    enabled: diff-count > 0;
                    clicked => { root.next-diff(); }
                }

                if root.view-mode == 0 : Rectangle { width: 8px; }

                if root.view-mode == 0 : Button {
                    text: "Copy →";
                    enabled: current-diff-index >= 0;
                    clicked => { root.copy-to-right(root.current-diff-index); }
                }

                if root.view-mode == 0 : Button {
                    text: "← Copy";
                    enabled: current-diff-index >= 0;
                    clicked => { root.copy-to-left(root.current-diff-index); }
                }

                Rectangle { width: 8px; }

                CheckBox {
                    text: "Ignore WS";
                    checked: root.ignore-whitespace;
                    toggled => { root.toggle-ignore-whitespace(); }
                }

                CheckBox {
                    text: "Ignore Case";
                    checked: root.ignore-case;
                    toggled => { root.toggle-ignore-case(); }
                }
            }
        }

        // Search & Replace bar
        if root.show-search && root.view-mode == 0 : Rectangle {
            height: 72px;
            background: Palette.background.darker(0.02);
            border-color: Palette.border;
            border-width: 1px;

            VerticalLayout {
                padding: 4px;
                spacing: 4px;

                // Search row
                HorizontalLayout {
                    spacing: 4px;
                    alignment: start;

                    Text {
                        width: 60px;
                        text: "Find:";
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                    }

                    search-input := LineEdit {
                        width: 250px;
                        text: root.search-query;
                        placeholder-text: "Search text...";
                        accepted(text) => {
                            root.search-query = text;
                            root.search(text);
                        }
                        edited(text) => {
                            root.search-query = text;
                            root.search(text);
                        }
                    }

                    Button {
                        text: "▲";
                        enabled: search-match-count > 0;
                        clicked => { root.search-prev(); }
                    }

                    Button {
                        text: "▼";
                        enabled: search-match-count > 0;
                        clicked => { root.search-next(); }
                    }

                    Text {
                        text: search-match-count > 0 ? "\{search-match-count} matches" : "";
                        font-size: 12px;
                        vertical-alignment: center;
                        color: Palette.foreground.transparentize(0.3);
                    }

                    Rectangle { horizontal-stretch: 1; }

                    Button {
                        text: "✕";
                        clicked => {
                            root.show-search = false;
                            root.search-query = "";
                            root.search("");
                        }
                    }
                }

                // Replace row
                HorizontalLayout {
                    spacing: 4px;
                    alignment: start;

                    Text {
                        width: 60px;
                        text: "Replace:";
                        font-size: 12px;
                        vertical-alignment: center;
                        horizontal-alignment: right;
                    }

                    replace-input := LineEdit {
                        width: 250px;
                        placeholder-text: "Replace with...";
                    }

                    Button {
                        text: "Replace";
                        enabled: search-match-count > 0;
                        clicked => { root.replace(root.search-query, replace-input.text); }
                    }

                    Button {
                        text: "Replace All";
                        enabled: search-match-count > 0;
                        clicked => { root.replace-all(root.search-query, replace-input.text); }
                    }
                }
            }
        }

        // Content area
        if root.view-mode == 2 : OpenDialog {
            left-path-input <=> root.open-left-path-input;
            right-path-input <=> root.open-right-path-input;
            is-folder-mode <=> root.open-is-folder-mode;
            browse-left => {
                if root.open-is-folder-mode {
                    root.open-folder-left();
                } else {
                    root.open-left-file();
                }
            }
            browse-right => {
                if root.open-is-folder-mode {
                    root.open-folder-right();
                } else {
                    root.open-right-file();
                }
            }
            compare => {
                root.start-compare(root.open-left-path-input, root.open-right-path-input, root.open-is-folder-mode);
            }
        }

        if root.view-mode == 0 : DiffView {
            diff-lines: root.diff-lines;
            current-diff-index: root.current-diff-index;
            left-title: root.left-path != "" ? root.left-path : "Left file";
            right-title: root.right-path != "" ? root.right-path : "Right file";
            copy-to-right(idx) => { root.copy-to-right(idx); }
            copy-to-left(idx) => { root.copy-to-left(idx); }
        }

        if root.view-mode == 1 : FolderView {
            items: root.folder-items;
            selected-index: root.folder-selected-index;
            item-double-clicked(idx) => { root.folder-item-double-clicked(idx); }
        }

        // Status bar
        Rectangle {
            height: 24px;
            background: Palette.background.darker(0.03);
            border-color: Palette.border;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 8px;
                spacing: 16px;

                Text {
                    text: root.status-text;
                    font-size: 12px;
                    vertical-alignment: center;
                }

                Text {
                    text: root.has-unsaved-changes ? "● Modified" : "";
                    font-size: 12px;
                    color: #b08800;
                    vertical-alignment: center;
                }
            }
        }
    }

    // Keyboard shortcuts
    FocusScope {
        width: 0;
        height: 0;
        key-pressed(event) => {
            // Cmd/Ctrl modifier
            if event.modifiers.meta || event.modifiers.control {
                if event.text == "s" {
                    root.save-left();
                    return accept;
                }
                if event.text == "f" {
                    root.show-search = !root.show-search;
                    return accept;
                }
                if event.text == "z" {
                    if event.modifiers.shift {
                        root.redo();
                    } else {
                        root.undo();
                    }
                    return accept;
                }
                if event.text == "t" {
                    root.new-tab();
                    return accept;
                }
                if event.text == "w" {
                    root.close-tab(root.active-tab-index);
                    return accept;
                }
                if event.text == "n" {
                    root.request-action(5);
                    return accept;
                }
            }
            // Alt + arrow for diff navigation
            if event.modifiers.alt {
                if event.text == Key.DownArrow {
                    root.next-diff();
                    return accept;
                }
                if event.text == Key.UpArrow {
                    root.prev-diff();
                    return accept;
                }
            }
            return reject;
        }
    }

    // Unsaved changes confirmation overlay
    ConfirmDialog {
        width: 100%;
        height: 100%;
        visible-flag: root.show-confirm-dialog;
        message: "You have unsaved changes. Discard and continue?";
        confirmed => {
            root.show-confirm-dialog = false;
            root.has-unsaved-changes = false;
            root.discard-and-proceed();
        }
        cancelled => {
            root.show-confirm-dialog = false;
            root.pending-action = 0;
        }
    }
}
