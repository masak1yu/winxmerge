import { Button, TextEdit, Palette, ScrollView } from "std-widgets.slint";
import { DiffView, DiffLineData } from "widgets/diff-view.slint";
import { ThemeColors } from "theme.slint";

export component WasmApp inherits Window {
    title: "WinXMerge Web";
    background: Palette.background;

    in-out property <string> left-text: "";
    in-out property <string> right-text: "";
    in-out property <string> left-title: "Left";
    in-out property <string> right-title: "Right";
    in-out property <[DiffLineData]> diff-lines;
    in-out property <int> diff-count: 0;
    in-out property <int> opt-font-size: 13;
    in-out property <int> current-diff-index: -1;
    in-out property <length> diff-scroll-y: 0px;

    callback compare();
    callback upload-left();
    callback upload-right();
    callback next-diff();
    callback prev-diff();

    VerticalLayout {
        padding: 0px;
        spacing: 0px;

        // Header
        Rectangle {
            height: 48px;
            background: Palette.background.darker(0.08);

            HorizontalLayout {
                padding-left: 16px;
                padding-right: 16px;
                alignment: space-between;

                Text {
                    text: "WinXMerge Web";
                    font-size: 16px;
                    font-weight: 700;
                    color: Palette.foreground;
                    vertical-alignment: center;
                }

                HorizontalLayout {
                    spacing: 8px;
                    alignment: end;

                    if root.diff-lines.length == 0: Button {
                        text: "Compare";
                        clicked => { root.compare(); }
                    }
                }
            }
        }

        if diff-lines.length == 0: HorizontalLayout {
            vertical-stretch: 1;
            spacing: 8px;
            padding: 12px;

            // Left input
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 4px;

                HorizontalLayout {
                    spacing: 6px;
                    alignment: space-between;

                    Text {
                        text: root.left-title;
                        font-size: 12px;
                        font-weight: 600;
                        color: Palette.foreground.transparentize(0.4);
                        vertical-alignment: center;
                    }

                    Button {
                        text: "Upload";
                        clicked => { root.upload-left(); }
                    }
                }

                TextEdit {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    text <=> root.left-text;
                    font-size: 13px;
                    placeholder-text: "Paste left text here...";
                }
            }

            // Right input
            VerticalLayout {
                horizontal-stretch: 1;
                spacing: 4px;

                HorizontalLayout {
                    spacing: 6px;
                    alignment: space-between;

                    Text {
                        text: root.right-title;
                        font-size: 12px;
                        font-weight: 600;
                        color: Palette.foreground.transparentize(0.4);
                        vertical-alignment: center;
                    }

                    Button {
                        text: "Upload";
                        clicked => { root.upload-right(); }
                    }
                }

                TextEdit {
                    horizontal-stretch: 1;
                    vertical-stretch: 1;
                    text <=> root.right-text;
                    font-size: 13px;
                    placeholder-text: "Paste right text here...";
                }
            }
        }

        if diff-lines.length > 0: VerticalLayout {
            vertical-stretch: 1;

            // Navigation bar
            Rectangle {
                height: 36px;
                background: Palette.background.darker(0.04);

                HorizontalLayout {
                    padding-left: 8px;
                    padding-right: 8px;
                    spacing: 8px;
                    alignment: space-between;

                    // Back to edit
                    HorizontalLayout {
                        spacing: 4px;
                        alignment: start;

                        Text {
                            text: "← Edit";
                            font-size: 12px;
                            color: Palette.foreground.transparentize(0.3);
                            vertical-alignment: center;

                            TouchArea {
                                mouse-cursor: pointer;
                                clicked => {
                                    root.diff-lines = [];
                                    root.current-diff-index = -1;
                                    root.diff-scroll-y = 0px;
                                }
                            }
                        }
                    }

                    // Diff navigation
                    HorizontalLayout {
                        spacing: 6px;
                        alignment: center;

                        Button {
                            text: "← Prev";
                            enabled: root.diff-count > 0 && root.current-diff-index > 0;
                            clicked => { root.prev-diff(); }
                        }

                        Text {
                            text: root.diff-count == 0 ? "No diffs"
                                : root.current-diff-index < 0 ? root.diff-count + " diffs"
                                : (root.current-diff-index + 1) + " / " + root.diff-count;
                            font-size: 12px;
                            color: Palette.foreground.transparentize(0.3);
                            vertical-alignment: center;
                            min-width: 80px;
                            horizontal-alignment: center;
                        }

                        Button {
                            text: "Next →";
                            enabled: root.diff-count > 0 && root.current-diff-index < root.diff-count - 1;
                            clicked => { root.next-diff(); }
                        }
                    }

                    // Spacer
                    Rectangle { width: 60px; }
                }
            }

            diff-view := DiffView {
                vertical-stretch: 1;
                diff-lines: root.diff-lines;
                current-diff-index: root.current-diff-index;
                left-title: root.left-title;
                right-title: root.right-title;
                editor-font-size: root.opt-font-size;
                show-line-numbers: true;
                word-wrap-mode: false;
                show-word-diff: true;
                context-menu-enabled: false;
                scroll-y <=> root.diff-scroll-y;
                next-diff => { root.next-diff(); }
                prev-diff => { root.prev-diff(); }
            }
        }
    }
}
