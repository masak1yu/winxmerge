import { Palette, ScrollView, Slider } from "std-widgets.slint";
import { ThemeColors } from "../theme.slint";

export component ImageView inherits Rectangle {
    in property <image> left-image;
    in property <image> right-image;
    in property <image> diff-image;
    in property <string> stats: "";
    in property <string> left-title: @tr("Left");
    in property <string> right-title: @tr("Right");
    in property <int> left-image-width: 0;
    in property <int> left-image-height: 0;
    in property <int> right-image-width: 0;
    in property <int> right-image-height: 0;
    // 0 = Fit, >0 = zoom percentage (10..400)
    in-out property <float> zoom-percent: 0;
    in-out property <bool> show-diff-panel: true;
    in property <image> overlay-image;
    // 0 = no overlay, 100 = full overlay
    in-out property <float> overlay-opacity: 0;

    VerticalLayout {
        // Stats bar
        Rectangle {
            height: 28px;
            background: Palette.background.darker(0.04);
            border-color: Palette.border;
            border-width: 1px;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;
                Text {
                    text: root.stats;
                    font-size: 12px;
                    vertical-alignment: center;
                    color: Palette.foreground;
                    horizontal-stretch: 1;
                }
                // Zoom label
                Text {
                    text: @tr("Zoom:");
                    font-size: 11px;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(0.3);
                }
                // Fit button
                Rectangle {
                    width: 36px;
                    height: 20px;
                    border-radius: 3px;
                    border-width: 1px;
                    border-color: root.zoom-percent == 0 ? Palette.accent-background : Palette.border;
                    background: root.zoom-percent == 0 ? Palette.accent-background.transparentize(0.5) : transparent;
                    TouchArea { clicked => { root.zoom-percent = 0; } }
                    Text { text: @tr("Fit"); font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
                // Zoom slider
                Slider {
                    minimum: 10;
                    maximum: 400;
                    value <=> root.zoom-percent;
                    width: 120px;
                    height: 20px;
                    enabled: root.zoom-percent > 0 || true; // always enabled
                }
                // Zoom percent display
                Text {
                    text: root.zoom-percent > 0 ? round(root.zoom-percent) + "%" : @tr("Fit");
                    font-size: 10px;
                    width: 40px;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(0.3);
                }
                // Blend slider (overlay opacity)
                Text {
                    text: @tr("Blend:");
                    font-size: 11px;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(0.3);
                }
                Slider {
                    minimum: 0;
                    maximum: 100;
                    value <=> root.overlay-opacity;
                    width: 80px;
                    height: 20px;
                }
                Text {
                    text: round(root.overlay-opacity) + "%";
                    font-size: 10px;
                    width: 32px;
                    vertical-alignment: center;
                    color: Palette.foreground.transparentize(0.3);
                }
                // Diff panel toggle
                Rectangle {
                    width: 72px;
                    height: 20px;
                    border-radius: 3px;
                    border-width: 1px;
                    border-color: root.show-diff-panel ? Palette.accent-background : Palette.border;
                    background: root.show-diff-panel ? Palette.accent-background.transparentize(0.5) : transparent;
                    TouchArea { clicked => { root.show-diff-panel = !root.show-diff-panel; } }
                    Text { text: @tr("Diff Panel"); font-size: 10px; horizontal-alignment: center; vertical-alignment: center; }
                }
            }
        }

        // Left / Right side-by-side
        HorizontalLayout {
            vertical-stretch: 2;
            spacing: 2px;

            // Left image panel
            Rectangle {
                horizontal-stretch: 1;
                border-color: Palette.border;
                border-width: 1px;

                VerticalLayout {
                    Rectangle {
                        height: 24px;
                        background: ThemeColors.removed-bg.transparentize(0.6);

                        Text {
                            x: 8px;
                            text: root.left-title;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                            color: Palette.foreground;
                            overflow: elide;
                        }
                    }

                    if root.zoom-percent == 0 : Rectangle {
                        vertical-stretch: 1;
                        Image {
                            source: root.left-image;
                            image-fit: contain;
                            width: 100%; height: 100%;
                        }
                        if root.overlay-opacity > 0 : Image {
                            source: root.overlay-image;
                            image-fit: contain;
                            width: 100%; height: 100%;
                            opacity: root.overlay-opacity / 100;
                        }
                    }
                    if root.zoom-percent > 0 : ScrollView {
                        vertical-stretch: 1;
                        Rectangle {
                            width: (root.left-image-width * root.zoom-percent / 100) * 1px;
                            height: (root.left-image-height * root.zoom-percent / 100) * 1px;
                            Image {
                                source: root.left-image;
                                width: 100%; height: 100%;
                                image-fit: fill;
                                image-rendering: pixelated;
                            }
                            if root.overlay-opacity > 0 : Image {
                                source: root.overlay-image;
                                width: 100%; height: 100%;
                                image-fit: fill;
                                image-rendering: pixelated;
                                opacity: root.overlay-opacity / 100;
                            }
                        }
                    }
                }
            }

            // Right image panel
            Rectangle {
                horizontal-stretch: 1;
                border-color: Palette.border;
                border-width: 1px;

                VerticalLayout {
                    Rectangle {
                        height: 24px;
                        background: ThemeColors.added-bg.transparentize(0.6);

                        Text {
                            x: 8px;
                            text: root.right-title;
                            font-size: 11px;
                            font-weight: 600;
                            vertical-alignment: center;
                            color: Palette.foreground;
                            overflow: elide;
                        }
                    }

                    if root.zoom-percent == 0 : Rectangle {
                        vertical-stretch: 1;
                        Image {
                            source: root.right-image;
                            image-fit: contain;
                            width: 100%; height: 100%;
                        }
                        if root.overlay-opacity > 0 : Image {
                            source: root.overlay-image;
                            image-fit: contain;
                            width: 100%; height: 100%;
                            opacity: root.overlay-opacity / 100;
                        }
                    }
                    if root.zoom-percent > 0 : ScrollView {
                        vertical-stretch: 1;
                        Rectangle {
                            width: (root.right-image-width * root.zoom-percent / 100) * 1px;
                            height: (root.right-image-height * root.zoom-percent / 100) * 1px;
                            Image {
                                source: root.right-image;
                                width: 100%; height: 100%;
                                image-fit: fill;
                                image-rendering: pixelated;
                            }
                            if root.overlay-opacity > 0 : Image {
                                source: root.overlay-image;
                                width: 100%; height: 100%;
                                image-fit: fill;
                                image-rendering: pixelated;
                                opacity: root.overlay-opacity / 100;
                            }
                        }
                    }
                }
            }
        }

        // Diff image panel
        if root.show-diff-panel : Rectangle {
            vertical-stretch: 1;
            border-color: Palette.border;
            border-width: 1px;

            VerticalLayout {
                Rectangle {
                    height: 24px;
                    background: Palette.background.darker(0.04);

                    Text {
                        x: 8px;
                        text: @tr("Diff  (changed pixels in red, identical pixels in gray)");
                        font-size: 11px;
                        font-weight: 600;
                        vertical-alignment: center;
                        color: Palette.foreground;
                    }
                }

                Image {
                    source: root.diff-image;
                    image-fit: contain;
                    vertical-stretch: 1;
                }
            }
        }
    }
}
