import { Palette } from "std-widgets.slint";
import { ThemeColors } from "../theme.slint";

export struct TabData {
    title: string,
    is-active: bool,
    has-unsaved: bool,
}

export component TabBar inherits Rectangle {
    in property <[TabData]> tabs;
    in property <int> active-index: 0;

    callback tab-clicked(int);
    callback tab-close(int);
    callback new-tab();
    callback tab-move-left(int);
    callback tab-move-right(int);

    height: 32px;
    background: Palette.background.darker(0.04);
    border-color: Palette.border;
    border-width: 1px;

    HorizontalLayout {
        alignment: start;
        spacing: 0;

        for tab[idx] in tabs: Rectangle {
            width: Math.min(200px, Math.max(100px, tab-text.preferred-width + 48px));
            height: 32px;
            background: tab.is-active ? Palette.background : Palette.background.darker(0.06);
            border-color: Palette.border;
            border-width: 1px;
            border-radius: 0;

            // Context menu for tab operations
            ContextMenuArea {
                Menu {
                    title: @tr("Tab");
                    MenuItem { title: @tr("Move Tab Left"); enabled: idx > 0; activated => { root.tab-move-left(idx); } }
                    MenuItem { title: @tr("Move Tab Right"); enabled: idx < root.tabs.length - 1; activated => { root.tab-move-right(idx); } }
                    MenuSeparator {}
                    MenuItem { title: @tr("Close Tab"); enabled: root.tabs.length > 1; activated => { root.tab-close(idx); } }
                }
            }

            // Tab click area (must be first so close button overlays it)
            TouchArea {
                clicked => { root.tab-clicked(idx); }
            }

            // Bottom highlight for active tab
            if tab.is-active : Rectangle {
                y: parent.height - 2px;
                height: 2px;
                background: Palette.accent-background;
            }

            HorizontalLayout {
                padding-left: 10px;
                padding-right: 4px;
                spacing: 4px;

                // Unsaved indicator
                Text {
                    width: tab.has-unsaved ? 8px : 0;
                    text: tab.has-unsaved ? "●" : "";
                    font-size: 8px;
                    color: ThemeColors.unsaved-indicator;
                    vertical-alignment: center;
                }

                // Tab title
                tab-text := Text {
                    text: tab.title;
                    font-size: 12px;
                    vertical-alignment: center;
                    overflow: elide;
                    horizontal-stretch: 1;
                    color: tab.is-active ? Palette.foreground : Palette.foreground.transparentize(0.3);
                }

                // Close button (only show when there are multiple tabs)
                if root.tabs.length > 1 : Rectangle {
                    width: 20px;
                    height: 20px;
                    border-radius: 3px;
                    background: close-touch.has-hover ? Palette.background.darker(0.15) : transparent;

                    Text {
                        text: "x";
                        font-size: 11px;
                        font-weight: 700;
                        horizontal-alignment: center;
                        vertical-alignment: center;
                        color: Palette.foreground.transparentize(0.4);
                    }

                    close-touch := TouchArea {
                        clicked => { root.tab-close(idx); }
                    }
                }
            }
        }

        // New tab button
        Rectangle {
            width: 32px;
            height: 32px;
            background: new-tab-touch.has-hover ? Palette.background.darker(0.08) : transparent;

            Text {
                text: "+";
                font-size: 16px;
                horizontal-alignment: center;
                vertical-alignment: center;
                color: Palette.foreground.transparentize(0.3);
            }

            new-tab-touch := TouchArea {
                clicked => { root.new-tab(); }
            }
        }
    }
}
