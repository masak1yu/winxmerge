import { VerticalBox, HorizontalBox, ListView, Palette } from "std-widgets.slint";

export struct DiffLineData {
    left-line-no: string,
    right-line-no: string,
    left-text: string,
    right-text: string,
    // 0=Equal, 1=Added, 2=Removed, 3=Modified
    status: int,
    is-current-diff: bool,
    diff-index: int, // -1 if not a diff, otherwise the diff block index
}

component DiffLineRow inherits Rectangle {
    in property <string> line-no;
    in property <string> text;
    in property <int> status;
    in property <bool> is-current;

    background: is-current ? current-bg : status == 1 ? #e6ffec : status == 2 ? #ffebe9 : status == 3 ? #fff8c5 : Palette.background;

    property <color> current-bg: status == 1 ? #ccffd8 : status == 2 ? #ffd7d5 : status == 3 ? #fff2a8 : Palette.background.darker(0.05);

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        spacing: 8px;

        // Line number
        Text {
            width: 40px;
            text: line-no;
            font-size: 12px;
            color: Palette.foreground.transparentize(0.5);
            horizontal-alignment: right;
            vertical-alignment: center;
            font-family: "monospace";
        }

        // Status marker
        Rectangle {
            width: 16px;
            Text {
                text: status == 1 ? "+" : status == 2 ? "-" : status == 3 ? "~" : " ";
                font-size: 12px;
                font-family: "monospace";
                color: status == 1 ? #22863a : status == 2 ? #cb2431 : status == 3 ? #b08800 : Palette.foreground.transparentize(0.5);
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // Text content
        Text {
            text: text;
            font-size: 13px;
            font-family: "monospace";
            vertical-alignment: center;
            overflow: elide;
        }
    }
}

// Location pane: minimap showing diff positions
component LocationPane inherits Rectangle {
    in property <[DiffLineData]> diff-lines;
    in property <int> current-diff-index: -1;

    width: 12px;
    background: Palette.background.darker(0.02);
    border-color: Palette.border;
    border-width: 1px;

    for line[idx] in diff-lines: Rectangle {
        y: diff-lines.length > 0 ? (idx * (parent.height - 2px) / diff-lines.length) : 0;
        height: diff-lines.length > 0 ? Math.max(2px, (parent.height - 2px) / diff-lines.length) : 0;
        x: 1px;
        width: parent.width - 2px;
        background: line.status == 0 ? transparent :
                    line.is-current-diff ? #0078d4 :
                    line.status == 1 ? #22863a :
                    line.status == 2 ? #cb2431 :
                    line.status == 3 ? #b08800 : transparent;
    }
}

export component DiffView inherits Rectangle {
    in property <string> left-title: "Left";
    in property <string> right-title: "Right";
    in property <[DiffLineData]> diff-lines;
    in property <int> current-diff-index: -1;

    callback copy-to-right(/* diff-index */ int);
    callback copy-to-left(/* diff-index */ int);

    border-color: Palette.border;
    border-width: 1px;

    VerticalLayout {
        // Header
        HorizontalLayout {
            height: 28px;

            Rectangle {
                background: Palette.background.darker(0.05);
                border-color: Palette.border;
                border-width: 1px;
                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: left-title;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // Spacer for merge button column
            Rectangle {
                width: 32px;
                background: Palette.background.darker(0.05);
                border-color: Palette.border;
                border-width: 1px;
            }

            Rectangle {
                background: Palette.background.darker(0.05);
                border-color: Palette.border;
                border-width: 1px;
                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: right-title;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // Spacer for location pane
            Rectangle {
                width: 12px;
                background: Palette.background.darker(0.05);
            }
        }

        // Diff content
        HorizontalLayout {
            // Left pane
            ListView {
                for line in diff-lines: DiffLineRow {
                    height: 24px;
                    line-no: line.left-line-no;
                    text: line.left-text;
                    status: line.status == 1 ? 0 : line.status;
                    is-current: line.is-current-diff;
                }
            }

            // Merge buttons column
            Rectangle {
                width: 32px;
                background: Palette.background.darker(0.01);
                border-color: Palette.border;
                border-width: 1px;

                ListView {
                    for line in diff-lines: Rectangle {
                        height: 24px;
                        if line.status != 0 : HorizontalLayout {
                            padding: 1px;
                            spacing: 1px;

                            // Copy left to right
                            Rectangle {
                                width: 14px;
                                height: 20px;
                                background: touch-r.has-hover ? Palette.background.darker(0.15) : transparent;
                                border-radius: 2px;
                                Text {
                                    text: "▶";
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    color: Palette.foreground.transparentize(0.3);
                                }
                                touch-r := TouchArea {
                                    clicked => { root.copy-to-right(line.diff-index); }
                                }
                            }

                            // Copy right to left
                            Rectangle {
                                width: 14px;
                                height: 20px;
                                background: touch-l.has-hover ? Palette.background.darker(0.15) : transparent;
                                border-radius: 2px;
                                Text {
                                    text: "◀";
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    color: Palette.foreground.transparentize(0.3);
                                }
                                touch-l := TouchArea {
                                    clicked => { root.copy-to-left(line.diff-index); }
                                }
                            }
                        }
                    }
                }
            }

            // Right pane
            ListView {
                for line in diff-lines: DiffLineRow {
                    height: 24px;
                    line-no: line.right-line-no;
                    text: line.right-text;
                    status: line.status == 2 ? 0 : line.status;
                    is-current: line.is-current-diff;
                }
            }

            // Location pane (minimap)
            LocationPane {
                diff-lines: root.diff-lines;
                current-diff-index: root.current-diff-index;
            }
        }
    }
}
