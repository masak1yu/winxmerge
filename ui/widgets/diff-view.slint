import { VerticalBox, HorizontalBox, ListView, Palette } from "std-widgets.slint";

export struct DiffLineData {
    left-line-no: string,
    right-line-no: string,
    left-text: string,
    right-text: string,
    // 0=Equal, 1=Added, 2=Removed, 3=Modified, 4=Moved
    status: int,
    is-current-diff: bool,
    diff-index: int, // -1 if not a diff, otherwise the diff block index
    // Syntax highlight: -1=none, 0=keyword, 1=string, 2=comment, 3=number, 4=function, etc.
    left-highlight: int,
    right-highlight: int,
}

component DiffLineRow inherits Rectangle {
    in property <string> line-no;
    in property <string> text;
    in property <int> status;
    in property <bool> is-current;
    in property <int> highlight-type: -1;
    in property <int> diff-idx: -1;
    in property <bool> show-line-no: true;
    in property <int> text-font-size: 13;

    callback line-clicked(int);

    background: is-current ? current-bg : status == 1 ? #e6ffec : status == 2 ? #ffebe9 : status == 3 ? #fff8c5 : status == 4 ? #e0e8ff : Palette.background;

    property <color> current-bg: status == 1 ? #ccffd8 : status == 2 ? #ffd7d5 : status == 3 ? #fff2a8 : status == 4 ? #c0d0ff : Palette.background.darker(0.05);

    HorizontalLayout {
        padding-left: 4px;
        padding-right: 4px;
        spacing: 8px;

        // Line number (clickable for diff selection)
        if show-line-no : Rectangle {
            width: 40px;
            background: line-no-touch.has-hover && diff-idx >= 0 ? Palette.background.darker(0.08) : transparent;

            Text {
                text: line-no;
                font-size: 12px;
                color: Palette.foreground.transparentize(0.5);
                horizontal-alignment: right;
                vertical-alignment: center;
                font-family: "monospace";
            }

            line-no-touch := TouchArea {
                clicked => {
                    if diff-idx >= 0 {
                        root.line-clicked(diff-idx);
                    }
                }
            }
        }

        // Status marker
        Rectangle {
            width: 16px;
            Text {
                text: status == 1 ? "+" : status == 2 ? "-" : status == 3 ? "~" : status == 4 ? "↕" : " ";
                font-size: 12px;
                font-family: "monospace";
                color: status == 1 ? #22863a : status == 2 ? #cb2431 : status == 3 ? #b08800 : status == 4 ? #3b5998 : Palette.foreground.transparentize(0.5);
                vertical-alignment: center;
                horizontal-alignment: center;
            }
        }

        // Text content
        Text {
            text: text;
            font-size: text-font-size * 1px;
            font-family: "monospace";
            vertical-alignment: center;
            overflow: elide;
            color: highlight-type == 0 ? #c678dd :  // keyword - purple
                   highlight-type == 1 ? #98c379 :  // string - green
                   highlight-type == 2 ? #7f848e :  // comment - gray
                   highlight-type == 3 ? #d19a66 :  // number - orange
                   highlight-type == 4 ? #61afef :  // function - blue
                   highlight-type == 5 ? #61afef :  // function.builtin - blue
                   highlight-type == 6 ? #e5c07b :  // type - yellow
                   highlight-type == 7 ? #e5c07b :  // type.builtin
                   highlight-type == 8 ? #e06c75 :  // variable - red
                   highlight-type == 9 ? #e06c75 :  // variable.builtin
                   highlight-type == 10 ? #56b6c2 : // operator - cyan
                   Palette.foreground;
        }
    }
}

// Location pane: minimap showing diff positions
component LocationPane inherits Rectangle {
    in property <[DiffLineData]> diff-lines;
    in property <int> current-diff-index: -1;

    width: 12px;
    background: Palette.background.darker(0.02);
    border-color: Palette.border;
    border-width: 1px;

    for line[idx] in diff-lines: Rectangle {
        y: diff-lines.length > 0 ? (idx * (parent.height - 2px) / diff-lines.length) : 0;
        height: diff-lines.length > 0 ? Math.max(2px, (parent.height - 2px) / diff-lines.length) : 0;
        x: 1px;
        width: parent.width - 2px;
        background: line.status == 0 ? transparent :
                    line.is-current-diff ? #0078d4 :
                    line.status == 1 ? #22863a :
                    line.status == 2 ? #cb2431 :
                    line.status == 3 ? #b08800 :
                    line.status == 4 ? #3b5998 : transparent;
    }
}

export component DiffView inherits Rectangle {
    in property <string> left-title: "Left";
    in property <string> right-title: "Right";
    in property <[DiffLineData]> diff-lines;
    in property <int> current-diff-index: -1;

    in property <bool> context-menu-enabled: true;
    in property <bool> show-line-numbers: true;
    in property <int> editor-font-size: 13;
    in property <int> editor-tab-width: 4;

    callback copy-to-right(/* diff-index */ int);
    callback copy-to-left(/* diff-index */ int);
    callback select-diff(/* diff-index */ int);
    callback next-diff();
    callback prev-diff();
    callback copy-left-text();
    callback copy-right-text();

    border-color: Palette.border;
    border-width: 1px;

    VerticalLayout {
        // Header
        HorizontalLayout {
            height: 28px;

            Rectangle {
                background: Palette.background.darker(0.05);
                border-color: Palette.border;
                border-width: 1px;
                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: left-title;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // Spacer for merge button column
            Rectangle {
                width: 32px;
                background: Palette.background.darker(0.05);
                border-color: Palette.border;
                border-width: 1px;
            }

            Rectangle {
                background: Palette.background.darker(0.05);
                border-color: Palette.border;
                border-width: 1px;
                HorizontalLayout {
                    padding-left: 8px;
                    Text {
                        text: right-title;
                        font-size: 12px;
                        font-weight: 600;
                        vertical-alignment: center;
                        overflow: elide;
                    }
                }
            }

            // Spacer for location pane
            if root.diff-lines.length > 0 : Rectangle {
                width: 12px;
                background: Palette.background.darker(0.05);
            }
        }

        // Diff content
        HorizontalLayout {
            // Left pane
            Rectangle {
                if root.context-menu-enabled : ContextMenuArea {
                    Menu {
                        title: "Context";
                        MenuItem { title: "Copy to Right →"; enabled: root.current-diff-index >= 0; activated => { root.copy-to-right(root.current-diff-index); } }
                        MenuItem { title: "← Copy to Left"; enabled: root.current-diff-index >= 0; activated => { root.copy-to-left(root.current-diff-index); } }
                        MenuSeparator {}
                        MenuItem { title: "Copy Text"; activated => { root.copy-left-text(); } }
                        MenuSeparator {}
                        MenuItem { title: "Next Difference"; activated => { root.next-diff(); } }
                        MenuItem { title: "Previous Difference"; activated => { root.prev-diff(); } }
                    }
                }

                left-list := ListView {
                    for line in diff-lines: DiffLineRow {
                        height: 24px;
                        line-no: line.left-line-no;
                        text: line.left-text;
                        status: line.status == 1 ? 0 : line.status;
                        is-current: line.is-current-diff;
                        highlight-type: line.left-highlight;
                        diff-idx: line.diff-index;
                        show-line-no: root.show-line-numbers;
                        text-font-size: root.editor-font-size;
                        line-clicked(idx) => { root.select-diff(idx); }
                    }
                }
            }

            // Merge buttons column
            Rectangle {
                width: 32px;
                background: Palette.background.darker(0.01);
                border-color: Palette.border;
                border-width: 1px;

                mid-list := ListView {
                    viewport-y: left-list.viewport-y;
                    for line in diff-lines: Rectangle {
                        height: 24px;
                        if line.status != 0 : HorizontalLayout {
                            padding: 1px;
                            spacing: 1px;

                            // Copy left to right
                            Rectangle {
                                width: 14px;
                                height: 20px;
                                background: touch-r.has-hover ? Palette.background.darker(0.15) : transparent;
                                border-radius: 2px;
                                Text {
                                    text: "▶";
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    color: Palette.foreground.transparentize(0.3);
                                }
                                touch-r := TouchArea {
                                    clicked => { root.copy-to-right(line.diff-index); }
                                }
                            }

                            // Copy right to left
                            Rectangle {
                                width: 14px;
                                height: 20px;
                                background: touch-l.has-hover ? Palette.background.darker(0.15) : transparent;
                                border-radius: 2px;
                                Text {
                                    text: "◀";
                                    font-size: 9px;
                                    horizontal-alignment: center;
                                    vertical-alignment: center;
                                    color: Palette.foreground.transparentize(0.3);
                                }
                                touch-l := TouchArea {
                                    clicked => { root.copy-to-left(line.diff-index); }
                                }
                            }
                        }
                    }
                }
            }

            // Right pane
            Rectangle {
                if root.context-menu-enabled : ContextMenuArea {
                    Menu {
                        title: "Context";
                        MenuItem { title: "← Copy to Left"; enabled: root.current-diff-index >= 0; activated => { root.copy-to-left(root.current-diff-index); } }
                        MenuItem { title: "Copy to Right →"; enabled: root.current-diff-index >= 0; activated => { root.copy-to-right(root.current-diff-index); } }
                        MenuSeparator {}
                        MenuItem { title: "Copy Text"; activated => { root.copy-right-text(); } }
                        MenuSeparator {}
                        MenuItem { title: "Next Difference"; activated => { root.next-diff(); } }
                        MenuItem { title: "Previous Difference"; activated => { root.prev-diff(); } }
                    }
                }

                right-list := ListView {
                    viewport-y: left-list.viewport-y;
                    for line in diff-lines: DiffLineRow {
                        height: 24px;
                        line-no: line.right-line-no;
                        text: line.right-text;
                        status: line.status == 2 ? 0 : line.status;
                        is-current: line.is-current-diff;
                        highlight-type: line.right-highlight;
                        diff-idx: line.diff-index;
                        show-line-no: root.show-line-numbers;
                        text-font-size: root.editor-font-size;
                        line-clicked(idx) => { root.select-diff(idx); }
                    }
                }
            }

            // Location pane (minimap) - only show when there are lines
            if root.diff-lines.length > 0 : LocationPane {
                diff-lines: root.diff-lines;
                current-diff-index: root.current-diff-index;
            }
        }
    }
}
